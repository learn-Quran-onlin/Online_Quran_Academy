    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lessonFrequency = document.getElementById('lessonFrequency');
            const lessonsPerMonthElement = document.getElementById('lessonsPerMonth');
            const months = document.getElementById('months');
            const originalPrice = document.getElementById('originalPrice');
            const total = document.getElementById('total');
            
            function calculateLessonsPerMonth() {
                return parseInt(lessonFrequency.value) * 4;
            }
    
            function calculateSubtotal() {
                const lessonsPerMonth = calculateLessonsPerMonth();
                const numberOfMonths = parseInt(months.value);
                return 4 * lessonsPerMonth * numberOfMonths;
            }
    
            function updateValues() {
                const lessonsPerMonth = calculateLessonsPerMonth();
                const subtotal = calculateSubtotal();
                
                lessonsPerMonthElement.textContent = `Lessons Per Month: ${lessonsPerMonth}`;
                originalPrice.textContent = `$${subtotal.toFixed(2)}`; // Show the subtotal
                
                // Set the total directly as the subtotal
                total.textContent = `$${subtotal.toFixed(2)}`;
            }
    
            lessonFrequency.addEventListener('change', updateValues);
            months.addEventListener('change', updateValues);
    
            // Initialize values on page load
            updateValues();
        });
    </script>    

<script>
    // cookie
      function setSecureCookie(cookieName, cookieValue, expirationDays) {
          var d = new Date();
          d.setTime(d.getTime() + (expirationDays * 24 * 60 * 60 * 1000));
          var expires = "expires=" + d.toUTCString();
          // Add "Secure" attribute to make it secure
          var secureFlag = "Secure";
          document.cookie = cookieName + "=" + cookieValue + ";" + expires + ";path=/;" + secureFlag;
      }
      // Call the function to set a secure cookie
      setSecureCookie("DarArqamCookie", "DarArqamValue", 30);
  </script>

