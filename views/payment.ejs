<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment</title>
    <link rel="icon" href="images/favicon.ico" type="image/ico">
    <link rel="icon" href="images/favicon-16x16.png" type="image/ico" sizes="16x16">
    <link rel="icon" href="images/favicon-32x32.png" type="image/png" sizes="32x32">
    <link rel="stylesheet" href="/css/paymentStyle.css" />

    <style>
        h2 {
            font-size: 20px;
            text-align: left;
        }

        h4 {
            font-size: 16px;
            text-align: center;
            font-weight: bold;
        }

        select {
            margin: 10px;
        }

        .discount-label {
            color: black;
            display: block;
            margin-top: 10px;
            font-size: 14px;
        }

        .discount-label.purple {
            color: rgb(223, 3, 223);
        }

        .discounted-price {
            display: none;
        }

        .original-price {
            text-decoration: none;
            /* Default: no text decoration */
        }

        .original-price.discount-applied {
            text-decoration: line-through;
            /* Apply strikethrough for discounted price */
        }

        /* Style for Subtotal, processing fee, and Total */
        .container p {
            text-align: left;
        }

        /* Style for Subtotal, processing fee, and Total values */
        .value {
            text-align: right;
        }

        #total {
            font-weight: bold;
        }


        .customer-info {
            margin-bottom: 15px;
        }

        .customer-info label {
            display: block;
            margin-bottom: 5px;
        }

        .customer-info input {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }

        .terms {
            margin-bottom: 25px;
        }

        /* style the new payment button */
        #payment-button {
            padding: 16px 32px;
            width: 100%;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            color: white;
            background-color: #944794;
            cursor: pointer;
        }

        #payment-button:hover {
            background-color: #631d63;
        }
    </style>

    </style>

</head>

<body>

    <div class="container">

        <form action="/create-order" method="POST">

            <!-- Hidden fields to add the lessonId and the months (qauantity) to use the default HTMl form. -->
            <input type="hidden" name="lessonId" value="<%= lesson.id %>">
            <input type="hidden" name="months" value="1">

            <div class="row">
                <div class="col" style="text-align: left;
                                        padding: 20px;
                                        border-radius: 10px;
                                        background-color: #f3f6f9;
                                        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);">
                    <h2 id="selectedLesson">Plan: <%= lesson.name %>
                    </h2>
                    <br>
                    <h4 id="lessonFrequency">Lessons Per Week: <%= lesson.frequency %>
                    </h4>
                    <br>
                    <h4 id="lessonsPerMonth">Lessons Per Month: <%= lesson.lessonsPerMonth %>
                    </h4>
                    <br>
                    <label for="months">Select the number of months:</label>
                    <select id="months">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                        <option value="7">7</option>
                        <option value="8">8</option>
                        <option value="9">9</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                    </select>
                    <p style="font-size: 14px; color: #666;">(Month = 4 Weeks)</p>
                    
                    <label class="discount-label" id="save3Label" style="text-align: center;">Save 3% (3+ months)</label>
                    <label class="discount-label" id="save7Label" style="text-align: center;">Save 7% (6+ months)</label>
                    <label class="discount-label" id="save15Label" style="text-align: center;">Save 15% (12 months)</label>
                    <br>
                    <hr>
                    <p>Subtotal: <span id="originalPrice" class="original-price value"></span><span
                            id="discountedPriceValue" class="discounted-price value"></span></p>
                    <p>Processing Fee: <span id="processingFee" class="value"></span></p>
                    <p style="color: rgb(224, 9, 224); font-size: 17px;"><b>Total:</b> <span id="total" class="value"></span></p>
                </div>

                <div class="col">
                    <h3 class="title">payment</h3>

                    <div class="customer-info">
                        <div class="input-wrapper">
                            <label for="fullName"></label>
                            <input type="text" id="fullName" name="fullName" required placeholder="Full Name"
                                style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 5px; background-color: #fff;">
                        </div>
                    </div>

                    <div class="customer-info">
                        <div class="input-wrapper">
                            <label for="email"></label>
                            <input type="email" id="email" name="email" required placeholder="Email"
                                style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 5px; background-color: #fff;">
                        </div>
                    </div>

                    <div class="terms" style="display: flex; align-items: center;">
                        <input type="checkbox" id="agreeToTerms" name="agreeToTerms" required
                            style="margin-right: 5px; transform: scale(1.2);">
                        <label for="agreeToTerms" style="font-size: 13px;">Agree to terms and conditions</label>
                    </div>

                    <div>
                        <p>Press the PayPal button to continue purchasing</p>
                    </div>

                    <!-- Do not use paypal smart buttons as they are only for donations not with no backend support (it's supports only webhooks interactions, but you have already used the paypal SDK) -->
                    <!-- <div id="paypal"></div> -->
                    <div>
                        <button type="submit" id="payment-button">Pay With Paypal</button>
                    </div>
                </div>
            </div>
        </form>

    </div>
    <script>
        const total = document.getElementById("total");
        console.log({ total });
        const price = <%= lesson.price %>;

        const monthsSelect = document.getElementById("months");
        const save3Label = document.getElementById("save3Label");
        const save7Label = document.getElementById("save7Label");
        const save15Label = document.getElementById("save15Label");
        const originalPriceElement = document.getElementById("originalPrice");
        const discountedPriceElement = document.getElementById("discountedPriceValue");
        const processingFeeElement = document.getElementById("processingFee");
        const totalElement = document.getElementById("total");

        const qauantityHiddenField = document.querySelector("[name='months']");

        // Add an event listener to the months select box
        monthsSelect.addEventListener("change", updateResult);

        // Function to update the result and label colors based on user input
        function updateResult() {
            const selectedMonths = parseInt(monthsSelect.value);
            qauantityHiddenField.value = selectedMonths // add months to the fields to use it in the backend.

            let originalPrice = selectedMonths * price;
            let discountedPrice = originalPrice;


            // Calculate originalPrice based on the selected card's price

            if (selectedMonths >= 3 && selectedMonths <= 5) {
                discountedPrice = Math.floor(originalPrice * 0.97); // 3% discount
                save3Label.classList.add("purple");
                save7Label.classList.remove("purple");
                save15Label.classList.remove("purple");
                originalPriceElement.classList.add("discount-applied"); // Apply strikethrough
            } else if (selectedMonths >= 6 && selectedMonths <= 11) {
                discountedPrice = Math.floor(originalPrice * 0.93); // 7% discount
                save7Label.classList.add("purple");
                save3Label.classList.remove("purple");
                save15Label.classList.remove("purple");
                originalPriceElement.classList.add("discount-applied"); // Apply strikethrough
            } else if (selectedMonths === 12) {
                discountedPrice = Math.floor(originalPrice * 0.85); // 15% discount
                save7Label.classList.remove("purple");
                save3Label.classList.remove("purple");
                save15Label.classList.add("purple");
                originalPriceElement.classList.add("discount-applied"); // Apply strikethrough
            } else {
                save3Label.classList.remove("purple");
                save7Label.classList.remove("purple");
                save15Label.classList.remove("purple");
                originalPriceElement.classList.remove("discount-applied"); // Remove strikethrough
            }

            // Round down the original price to remove decimal places
            originalPrice = Math.floor(originalPrice);

            // Round down the discounted price to remove decimal places
            discountedPrice = Math.floor(discountedPrice);

            originalPriceElement.textContent = ` $${originalPrice}`; // Add dollar sign and display as an integer

            // Calculate the processing fee for PayPal (5% of the discounted price)
            const processingFee = (discountedPrice * 0.05).toFixed(2);
            processingFeeElement.textContent = ` $${processingFee}`; // Add dollar sign and two decimal places

            // Calculate the total (discounted price + processing fee)
            const total = (Number(discountedPrice) + Number(processingFee)).toFixed(2);
            totalElement.textContent = ` $${total}`; // Add dollar sign and two decimal places

            if (discountedPrice !== originalPrice) {
                discountedPriceElement.textContent = ` $${discountedPrice}`; // Add dollar sign and display as an integer
                discountedPriceElement.style.display = "inline"; // Show the discounted price
            } else {
                discountedPriceElement.style.display = "none"; // Hide the discounted price if no discount
            }
        }

        // Initial calculation on page load
        // Add an event listener to each card to toggle the 'active' class
        const cardLinks = document.querySelectorAll('.card-container a');
        cardLinks.forEach(link => {
            link.addEventListener('click', () => {
                // Remove 'active' class from all links
                cardLinks.forEach(link => link.classList.remove('active'));
                // Add 'active' class to the clicked link
                link.classList.add('active');
                // Update the result based on the selected card
                updateResult();
            });
        });
        // Initial calculation on page load
        updateResult();
    </script>
</body>

</html>