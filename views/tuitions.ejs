    <!-- Plans -->
    <section class="packages-section" id="plans">
      <div class="bless-sentence">
        <p>We are blessed and honored to be serving Muslims worldwide through Quality, Dedication, and Innovation.</p>
        <p>Join us and learn with our Expert Teachers</p>
      </div>
      <!-- <h2 class="packages-header">Our Plans</h2> -->
    </div>
    <div class="headline">
      <i class="fas fa-clock clock-icon"></i>
      30 Mins Lesson
    </div>   
    <div class="headline">
      <i class="fas fa-clock clock-icon"></i>
      45 Mins Lesson
    </div>
    <div class="headline">
      <i class="fas fa-clock clock-icon"></i>
      60 Mins Lesson
    </div>
    <div class="card-container">
      <% lessons.filter(lesson=> lesson.time == 30).forEach(lesson => { %>
        <a href="/payment?lessonId=<%= lesson.id %>" target="_blank" data-price="<%= lesson.price %>">
          <div class="card" id="<%= lesson.id %>">
            <div class="part1">
              <b>
                Limited Time: 20% OFF
              </b>
            </div>
            <div class="part2">
              <div class="lessonprice">
                US$ <del>10</del>
                <span style="font-size: 40px; font-weight: bold">
                  <%= lesson.lessonprice %>
                </span>
                / Hour
              </div>
            </div>
            <div class="part3">
              1-on-1 Online lessons
            </div>
          </div>
        </a>
        <% }); %>
    </div>
    <div class="packages-subheader">
      <p>Customize your plan according to your needs with flexible lesson rate</p>
      <p>Select the number of lessons per week and the duration in months</p>
   </div>
