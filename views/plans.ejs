<!DOCTYPE html>
<html>
    <head>
        <title>Plans and Pricing</title>
        <meta charset="UTF-8" />
        <meta name="description"
          content="Plans of Dar Arqam" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" href="images/favicon.ico" type="image/ico" />
        <link rel="icon" href="images/favicon-16x16.png" type="image/ico" sizes="16x16" />
        <link rel="icon" href="images/favicon-32x32.png" type="image/png" sizes="32x32" />
        <link rel="stylesheet" href="/css/homeStyle.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
        <script src="/javaScript/homeScript.js"></script>
    </head>
    <body>
      <nav>
        <div class="logo">
            <a id="web-logo" href="https://dararqam.com"><img src="images/logo.jpg" alt="Dar Arqam Logo" /></a>
            <a id="web-name" href="https://dararqam.com"  ><img src="images/dararqam.png" style="height: 34px; width: 135px;" alt="Dar Arqam" /></a>
        </div>
    
        <button class="menu-button"><i class="fa fa-2xl fa-bars"></i></button>
    
        <ul class="nav-links">
            <li><a href="https://dararqam.com#hero">Home</a></li>
            <li><a href="https://dararqam.com#about">About</a></li>
            <li><a href="https://dararqam.com#courses">Courses</a></li>
            <a href="">Plans</a>
            <li><a href="https://dararqam.com#registration">Contact</a></li>
            <!-- <li><a href="#" id="login">Login</a></li> -->
            <!-- <li><a href="#" id="register">Sign Up</a></li> -->
        </ul>
        
    </nav>

    <!-- Plans -->
    <section class="packages-section" id="plans">
      <div class="bless-sentence">
        <p>We are blessed and honored to be serving Muslims worldwide through Quality, Dedication, and Innovation.</p>
        <p>Join us and learn with Professional Teachers</p>
      </div>
      <h2 class="packages-header">Our Plans</h2>
      <div class="packages-subheader">
        <p>These plans cover all courses. You can take one or several courses within the same plan.</p>
      </div>
      <!-- 30 Mins Lesson -->
      <div class="headline">
        <i class="fas fa-clock clock-icon"></i>
        30 Mins Lesson
      </div>
      <div class="card-container">
        <% lessons.filter(lesson=> lesson.time == 30).forEach(lesson => { %>
          <a href="/payment?lessonId=<%= lesson.id %>" target="_blank" data-price="<%= lesson.price %>">
            <div class="card" id="<%= lesson.id %>">
              <div class="part1">
                <b>
                  <%= lesson.lessonsPerWeek %> Lesson / Week
                </b>
              </div>
              <div class="part2">
                <div class="price">
                  US$
                  <span style="font-size: 40px; font-weight: bold">
                    <%= lesson.price %>
                  </span>
                  / Month
                </div>
              </div>
              <div class="part3">
                <%= lesson.lessonsPerMonth %> Lessons / Month
              </div>
              <div class="part6">
                <p>
                  <b><span style="color: #fd0000">Save 3%</span></b><br />3 months = US$ <del>
                    <%= lesson.price * 3 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 3) - ((lesson.price * 3) * 0.03)) %>
                  </b>
                </p>
              </div>
              <div class="part4">
                <p>
                  <b><span style="color: #fd0000">Save 7%</span></b><br />6 months = US$ <del>
                    <%= lesson.price * 6 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 6) - ((lesson.price * 6) * 0.07)) %>
                  </b>
                </p>
              </div>
              <div class="part5">
                <p>
                  <b><span style="color: #fd0000">Save 15%</span></b><br />12 months = US$ <del>
                    <%= lesson.price * 12 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 12) - ((lesson.price * 12) * 0.15)) %>
                  </b>
                </p>
              </div>
            </div>
          </a>
          <% }); %>
      </div>
      <br />

      <!-- 60 Mins Lesson -->
      <div class="headline">
        <i class="fas fa-clock clock-icon"></i>
        60 Mins Lesson
      </div>
      <div class="card-container">
        <% lessons.filter(lesson=> lesson.time == 60).forEach(lesson => { %>
          <a href="/payment?lessonId=<%= lesson.id %>" target="_blank" data-price="<%= lesson.price %>">
            <div class="card" id="<%= lesson.id %>">
              <div class="part1">
                <b>
                  <%= lesson.lessonsPerWeek %> Lesson / Week
                </b>
              </div>
              <div class="part2">
                <div class="price">
                  US$
                  <span style="font-size: 40px; font-weight: bold">
                    <%= lesson.price %>
                  </span>
                  / Month
                </div>
              </div>
              <div class="part3">
                <%= lesson.lessonsPerMonth %> Lessons / Month
              </div>
              <div class="part6">
                <p>
                  <b><span style="color: #fd0000">Save 3%</span></b><br />3 months = US$ <del>
                    <%= lesson.price * 3 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 3) - ((lesson.price * 3) * 0.03)) %>
                  </b>
                </p>
              </div>
              <div class="part4">
                <p>
                  <b><span style="color: #fd0000">Save 7%</span></b><br />6 months = US$ <del>
                    <%= lesson.price * 6 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 6) - ((lesson.price * 6) * 0.07)) %>
                  </b>
                </p>
              </div>
              <div class="part5">
                <p>
                  <b><span style="color: #fd0000">Save 15%</span></b><br />12 months = US$ <del>
                    <%= lesson.price * 12 %>
                  </del>
                  <b>
                    <%= Math.floor((lesson.price * 12) - ((lesson.price * 12) * 0.15)) %>
                  </b>
                </p>
              </div>
            </div>
          </a>
          <% }); %>
      </div>
    </section>
    <br><br>
    <%- include("layout/footer") -%>
    </body>

</html>