    countrySelect.appendChild(option);
  });

  // Populate time zone dropdown
  timeZones.forEach(zone => {
    const option = document.createElement("option");
    option.value = zone;
    option.textContent = zone;
    timeZoneSelect.appendChild(option);
  });

  // List of days
  const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

// List of time slots from 5 AM to 11 PM
const times = [];
for (let hour = 5; hour <= 23; hour++) {
    let ampm = hour < 12 ? "AM" : "PM";
    let displayHour = hour > 12 ? hour - 12 : hour;
    times.push(`${displayHour}:00 ${ampm}`);
    times.push(`${displayHour}:30 ${ampm}`);
}


function populateDropdown(id, options) {
    const dropdown = document.getElementById(id);
    options.forEach(option => {
        const div = document.createElement("div");
        div.textContent = option;
        div.onclick = function () {
            addSelection(id.replace("-dropdown", "-box"), option);
            dropdown.style.display = "none";
        };
        dropdown.appendChild(div);
    });
}

// Populate the dropdown lists
document.addEventListener("DOMContentLoaded", function () {
    populateDropdown("days-dropdown", days);
    populateDropdown("times-dropdown", times);

    // Populate country dropdown
    const countrySelect = document.getElementById("country");
    countries.forEach(country => {
        const option = document.createElement("option");
        option.value = country;
        option.textContent = country;
        countrySelect.appendChild(option);
    });

    // Populate time zone dropdown
    const timeZoneSelect = document.getElementById("time-zone");
    timeZones.forEach(zone => {
        const option = document.createElement("option");
        option.value = zone;
        option.textContent = zone;
        timeZoneSelect.appendChild(option);
    });
});

function toggleDropdown(id) {
    const dropdown = document.getElementById(id);
    dropdown.style.display = dropdown.style.display === "block" ? "none" : "block";
}

function addSelection(boxId, value) {
    const box = document.getElementById(boxId);
    
    // Check if value is already selected
    if ([...box.children].some(child => child.textContent.includes(value))) return;

    const div = document.createElement("div");
    div.className = "selected-item";
    div.textContent = value;
    
    const removeBtn = document.createElement("button");
    removeBtn.textContent = "x";
    removeBtn.onclick = function () {
        div.remove();
    };

    div.appendChild(removeBtn);
    box.appendChild(div);
}

      // courses
      const courseSelect = document.getElementById("course");
  const courseContainer = document.getElementById("course-container");
  const selectedCoursesInput = document.getElementById("selected-courses");
  const errorText = document.getElementById("course-error");
  let selectedCourses = [];

  courseSelect.addEventListener("change", function () {
    const selectedValue = this.value;
    const selectedText = this.options[this.selectedIndex].text;

    if (selectedValue && !selectedCourses.includes(selectedValue)) {
      selectedCourses.push(selectedValue);
      updateSelectedCourses();
    }
  });

  function updateSelectedCourses() {
    courseContainer.innerHTML = "";
    selectedCourses.forEach(course => {
      const courseTag = document.createElement("div");
      courseTag.classList.add("selected-course");
      courseTag.innerHTML = `
        ${courseSelect.querySelector(`option[value="${course}"]`).text}
        <button type="button" onclick="removeCourse('${course}')">&times;</button>
      `;
      courseContainer.appendChild(courseTag);
    });
    selectedCoursesInput.value = selectedCourses.join(",");
    validateSelection();
  }

  function removeCourse(course) {
    selectedCourses = selectedCourses.filter(c => c !== course);
    updateSelectedCourses();
  }

  function validateSelection() {
    if (selectedCourses.length === 0) {
      errorText.classList.remove("d-none");
    } else {
      errorText.classList.add("d-none");
    }
  }

  document.querySelector("form").addEventListener("submit", function (event) {
    if (selectedCourses.length === 0) {
      event.preventDefault();
      errorText.classList.remove("d-none");
    }
  });
      </script>
